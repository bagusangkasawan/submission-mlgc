# === Local Development ===
# Path ke folder model lokal (berisi model.json + shard files)
MODEL_LOCAL_PATH=./model.json

# === Production (Cloud Run) ===
# Hapus MODEL_LOCAL_PATH dan set ini saat deploy
# MODEL_BUCKET_NAME=submissionmlgc-namakamu-model
# MODEL_FILE_NAME=model.json

# === Server ===
PORT=8080

# === Firestore (lokal) ===
# Jalankan dulu: gcloud auth application-default login
# Atau set path ke service account key:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
